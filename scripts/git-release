#!/usr/bin/env bash
# git release — read the version from the repo's source of truth (pyproject.toml /
# package.json / VERSION.txt, auto-detected) and create an annotated tag v<version>
# on HEAD. Refuses on a dirty tree or an existing tag. Does NOT push.
#
#   git release            # tag v<version>; then: git push --follow-tags
#
# The release CI verifies the pushed tag matches the source of truth; this keeps the
# tag-side honest by deriving it — never typed by hand. Companion: `git bump`.

set -euo pipefail

# Resolve our real directory (through the install.sh symlink) to source _sot.sh.
_src="${BASH_SOURCE[0]}"
while [[ -L "$_src" ]]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"; _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
source "$(cd -P "$(dirname "$_src")" && pwd)/_sot.sh"

sot_kind >/dev/null   # errors out if there's no source of truth

v="$(sot_read)"
if [[ -z "$v" ]]; then
  echo "git release: could not read the version from the source of truth" >&2
  exit 1
fi

tag="v$v"
if git rev-parse "$tag" >/dev/null 2>&1; then
  echo "git release: tag $tag already exists" >&2
  exit 1
fi

if [[ -n "$(git status --porcelain)" ]]; then
  echo "git release: working tree is dirty; commit or stash before tagging" >&2
  exit 1
fi

git tag -a "$tag" -m "Release $tag"
echo "tagged $tag (HEAD: $(git rev-parse --short HEAD))"
echo "push with: git push --follow-tags"
