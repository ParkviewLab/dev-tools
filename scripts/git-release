#!/usr/bin/env bash
# git release — read [project].version from ./pyproject.toml and create an annotated tag v<version>.
# Does NOT push; tells you the command to push.
#
# Convention: ParkviewLab Python projects use pyproject.toml as the single source of truth for
# version. The release CI verifies that the pushed tag matches pyproject. This script keeps the
# tag-side of that contract honest by deriving the tag from pyproject — never typed by hand.
#
# Companion: `git bump` (in this same dev-tools repo) bumps pyproject + commits. Typical flow:
#   git bump patch    # bump pyproject + commit
#   git release       # tag derived from pyproject
#   git push --follow-tags

set -euo pipefail

if [[ ! -f pyproject.toml ]]; then
  echo "git release: no pyproject.toml in $(pwd)" >&2
  exit 1
fi

# Read [project].version from pyproject.toml. tomllib is stdlib in 3.11+.
v=$(uv run --quiet python -c 'import tomllib;print(tomllib.load(open("pyproject.toml","rb"))["project"]["version"])')

if [[ -z "$v" ]]; then
  echo "git release: could not read [project].version from pyproject.toml" >&2
  exit 1
fi

tag="v$v"

if git rev-parse "$tag" >/dev/null 2>&1; then
  echo "git release: tag $tag already exists" >&2
  exit 1
fi

# Refuse on a dirty worktree — release tags should point at clean state.
if [[ -n "$(git status --porcelain)" ]]; then
  echo "git release: working tree is dirty; commit or stash before tagging" >&2
  exit 1
fi

git tag -a "$tag" -m "Release $tag"
echo "tagged $tag (HEAD: $(git rev-parse --short HEAD))"
echo "push with: git push --follow-tags"
